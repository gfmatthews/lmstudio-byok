{
	"name": "lmstudio-byok-chat-provider",
	"publisher": "NullSetIndustries",
	"displayName": "LM Studio Copilot Chat Provider",
	"description": "Use LM Studio models on your local machine with VSCode Copilot Chat.",
	"license": "MIT",
	"icon": "assets/LogoV1.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/gfmatthews/lmstudio-byok"
	},
	"version": "0.3.1",
	"engines": {
		"vscode": "^1.110.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"activationEvents": [
		"onStartupFinished",
		"onCommand:lmstudio.refreshModels",
		"onCommand:lmstudio.testConnection",
		"onCommand:lmstudio.showWelcome",
		"onView:lmstudioModels"
	],
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "lmstudio",
				"displayName": "LM Studio"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "lmstudio-explorer",
					"title": "LM Studio",
					"icon": "$(chip)"
				}
			]
		},
		"views": {
			"lmstudio-explorer": [
				{
					"id": "lmstudioModels",
					"name": "Models"
				}
			]
		},
		"commands": [
			{
				"command": "lmstudio.refreshModels",
				"title": "Refresh Available Models",
				"category": "LM Studio",
				"icon": "$(refresh)"
			},
			{
				"command": "lmstudio.testConnection",
				"title": "Test Connection",
				"category": "LM Studio"
			},
			{
				"command": "lmstudio.showWelcome",
				"title": "Show Welcome",
				"category": "LM Studio"
			},
			{
				"command": "lmstudio.toggleModelVisibility",
				"title": "Toggle Model Visibility",
				"category": "LM Studio",
				"icon": "$(eye)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "lmstudio.refreshModels",
					"when": "view == lmstudioModels",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "lmstudio.toggleModelVisibility",
					"when": "view == lmstudioModels",
					"group": "inline"
				}
			]
		},
		"configuration": {
			"title": "LM Studio",
			"properties": {
				"lmstudio.baseUrl": {
					"type": "string",
					"default": "http://localhost:1234",
					"description": "The base URL for your LM Studio server. Default is http://localhost:1234. In dev containers and remote environments, localhost is automatically rewritten to host.docker.internal to reach the host machine."
				},
				"lmstudio.apiKey": {
					"type": "string",
					"description": "Your LM Studio API key (optional for local instances). You can also set this via the LMSTUDIO_API_KEY environment variable.",
					"scope": "application"
				},
				"lmstudio.verboseLogging": {
					"type": "boolean",
					"default": false,
					"description": "Enable verbose diagnostic logging to the 'LM Studio' output channel for troubleshooting.",
					"scope": "application"
				}
			}
		},
		"viewsWelcome": [
			{
				"view": "lmstudioModels",
				"contents": "No models detected running on your machine.\n\nStart the server, ensure it's configured in [extension settings](command:workbench.action.openSettings?%22lmstudio%22) and that you have a model loaded. Then hit refresh to load a model.\n\n[Refresh Models](command:lmstudio.refreshModels)"
			}
		]
	},
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && node esbuild.mjs",
		"check-types": "tsc --noEmit",
		"watch": "node esbuild.mjs --watch",
		"lint": "eslint",
		"package": "npm run check-types && node esbuild.mjs --production",
		"vsce:package": "vsce package"
	},
	"dependencies": {
		"gpt-tokenizer": "^3.0.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/vscode": "^1.110.0",
		"@vscode/vsce": "^3.3.2",
		"esbuild": "^0.27.4",
		"eslint": "^9.13.0",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.26.0"
	}
}
